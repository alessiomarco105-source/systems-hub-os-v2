{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "systems_hub.task_manifest/v1",
  "title": "Systems Hub Task Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task_id",
    "role",
    "scope",
    "provider",
    "model",
    "source_root",
    "context",
    "permissions",
    "budget",
    "prompt",
    "output",
    "validation"
  ],
  "properties": {
    "schema": { "const": "systems_hub.task_manifest/v1" },
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "role": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "scope": { "type": "string", "pattern": "^(company|personal|project:[a-z0-9-]+|capability:[a-z0-9-]+)$" },
    "provider": { "const": "deepseek" },
    "model": { "enum": ["deepseek-v4-flash", "deepseek-v4-pro"] },
    "source_root": { "const": "." },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_files", "allowed_data_classes", "max_files", "max_total_bytes"],
      "properties": {
        "allowed_files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowed_data_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["public", "internal", "private", "protected"] }
        },
        "max_files": { "type": "integer", "minimum": 1, "maximum": 20 },
        "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "write", "external_actions"],
      "properties": {
        "tools": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["read", "grep", "find", "ls"] }
        },
        "write": { "const": false },
        "external_actions": { "const": false }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_input_tokens", "max_output_tokens", "max_total_tokens", "max_cost_usd"],
      "properties": {
        "max_input_tokens": { "type": "integer", "minimum": 1 },
        "max_output_tokens": { "type": "integer", "minimum": 1 },
        "max_total_tokens": { "type": "integer", "minimum": 1 },
        "max_cost_usd": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "prompt": { "type": "string", "minLength": 20, "maxLength": 12000 },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "max_words", "required_sections", "allow_preamble"],
      "properties": {
        "format": { "enum": ["markdown", "json"] },
        "max_words": { "type": "integer", "minimum": 1, "maximum": 5000 },
        "required_sections": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allow_preamble": { "type": "boolean" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbidden_patterns",
        "required_patterns",
        "section_required_patterns",
        "require_evidence_labels"
      ],
      "properties": {
        "forbidden_patterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_patterns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "section_required_patterns": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "require_evidence_labels": { "type": "boolean" }
      }
    }
  }
}
