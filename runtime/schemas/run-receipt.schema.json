{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "systems_hub.run_receipt/v1",
  "title": "Systems Hub Run Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run_id",
    "task_id",
    "started_at",
    "finished_at",
    "provider",
    "model",
    "context",
    "usage",
    "output",
    "validation",
    "promotion"
  ],
  "properties": {
    "schema": { "const": "systems_hub.run_receipt/v1" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "task_kind": { "enum": ["standard", "review"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "context": {
      "type": "object",
      "required": ["files", "file_count", "total_bytes"],
      "properties": {
        "files": { "type": "array", "items": { "type": "string" } },
        "file_count": { "type": "integer" },
        "total_bytes": { "type": "integer" }
      }
    },
    "usage": {
      "type": "object",
      "required": ["input", "output", "cache_read", "cache_write", "total_tokens", "cost_usd"],
      "properties": {
        "input": { "type": "integer" },
        "output": { "type": "integer" },
        "cache_read": { "type": "integer" },
        "cache_write": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "cost_usd": { "type": "number" }
      }
    },
    "output": {
      "type": "object",
      "required": ["path", "sha256", "word_count"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "word_count": { "type": "integer" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["status", "checks", "failures"],
      "properties": {
        "status": { "enum": ["pass", "fail"] },
        "checks": { "type": "array", "items": { "type": "string" } },
        "failures": { "type": "array", "items": { "type": "string" } }
      }
    },
    "promotion": {
      "type": "object",
      "required": ["eligible", "human_review_required"],
      "properties": {
        "eligible": { "type": "boolean" },
        "human_review_required": { "const": true }
      }
    },
    "review": {
      "type": "object",
      "required": ["source_receipt", "source_output", "source_output_sha256"],
      "properties": {
        "source_receipt": { "type": "string" },
        "source_output": { "type": "string" },
        "source_output_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
